generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash      String
  resetToken        String?  @unique
  resetTokenExpiry  DateTime?
  emailVerified           Boolean   @default(false)
  verificationToken       String?   @unique
  verificationTokenExpiry DateTime?
  phone          String?
  role           String   @default("customer")
  // For role='staff' users: array of permission keys (e.g. ['orders.read',
  // 'inventory.write']). Null/empty = no admin access. Super-admins
  // (role='admin') bypass this and have implicit access to everything.
  permissions    Json?
  // Bumped on staff revoke / explicit force-logout. JWT carries the
  // version it was signed with; verifyToken rejects when the User row's
  // current version is higher → forces re-login.
  tokenVersion   Int      @default(0)
  lastLoginAt    DateTime?
  savedAddresses Json?
  wishlistIds    Json?
  marketingOptIn Boolean  @default(false)
  marketingToken String?  @unique
  // Marks the customer as a wholesale dealer (تاجر جملة). Filterable on the
  // customer list and surfaced as a separate count on the valuation page.
  isWholesale    Boolean  @default(false)
  loyaltyPoints  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders  Order[]
  cart    Cart?
  reviews Review[]
  bookAccesses BookAccess[]
  oauthAccounts OAuthAccount[]
  bookOrders    BookOrder[]
  devices       BookDevice[]
  customerTransactions CustomerTransaction[]
  campaignRecipients CampaignRecipient[]
  wishlistShareLinks WishlistShareLink[]
  loyaltyTransactions LoyaltyTransaction[]
  referralRewards    ReferralReward[]
  returnRequests     ReturnRequest[]
  children           Child[]

  @@index([role])
  @@index([isWholesale])
}

model Campaign {
  id              String   @id @default(cuid())
  name            String
  channel         String   @default("email") // email | whatsapp (placeholder)
  segmentKey      String   @default("all")   // matches segments in /api/admin/customers
  segmentFilters  Json?    // { boughtProduct?, notBoughtProduct?, governorate? }
  subject         String
  bodyHtml        String   @db.LongText
  couponCode      String?  @unique // optional coupon to attach; unique so an order's coupon maps to at most one campaign for conversion attribution
  status          String   @default("draft") // draft | sending | sent | failed
  recipientCount  Int      @default(0)
  sentCount       Int      @default(0)
  openedCount     Int      @default(0)
  clickedCount    Int      @default(0)
  conversionCount Int      @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  // Attribution: which admin/staff created the campaign.
  createdByUserId String?
  // ---- Daily-drip + plain-text editor ----
  // bodyText is the new authoritative source for the message; bodyHtml
  // is derived from it at send time via renderPlainTextEmail() so the
  // assistant doesn't have to write HTML. Legacy campaigns whose
  // bodyText is null still send via the legacy bodyHtml path.
  bodyText        String?  @db.LongText
  ctaLabel        String?
  ctaUrl          String?
  // dailyLimit recipients per "send-daily-batch" click — defaults to 5
  // so the inbox doesn't look algorithmic. Drops to 0 to disable drip.
  dailyLimit      Int      @default(5)
  lastBatchAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recipients CampaignRecipient[]
  @@index([status])
}

model CampaignRecipient {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String
  status      String   @default("queued") // queued | sent | failed | bounced
  errorMessage String? @db.Text
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  orderId     String?  // attribution if a conversion happened
  createdAt   DateTime @default(now())

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
}

model Product {
  id                 String   @id @default(cuid())
  slug               String   @unique
  name               String
  nameEn             String?
  shortDescription   String   @db.Text
  shortDescriptionEn String?  @db.Text
  description        String   @db.LongText
  descriptionEn      String?  @db.LongText
  price              Float
  priceUsd           Float    @default(0)
  // Optional wholesale price for the Zakat valuation engine. When null,
  // the calculator falls back to retail × 0.85 as the wholesale proxy.
  wholesalePrice     Float?
  category           String
  subcategory        String?
  variants           Json?
  tags               Json
  images             Json
  inStock            Boolean  @default(true)
  stock              Int      @default(500)
  variantStocks      Json?    // { "0": 250, "1": 250 } — per-variant stock by index. Total `stock` = sum.
  featured           Boolean  @default(false)
  videos             Json?
  videoUrl           String?
  weight             Float    @default(0)
  regionalPricing    Json?
  source             String   @default("static")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Optional age range — used by the FB AI assistant to filter the
  // catalogue to age-appropriate items when a buyer says "my kid
  // is 5". Products without these still appear under "all ages".
  minAge       Int?
  maxAge       Int?
  ageCategory  String?   // 'toddler' | 'preschool' | 'primary' | 'tween' | 'teen'
  // True when the product needs an adult to use it with the child
  // (board game, craft kit, etc.). Surfaced as a chip on the
  // product card and in Amin's catalogue context, mirroring the
  // existing field on the Book model.
  needsParentalGuide Boolean @default(false)
  // When true, the product is not yet available for purchase.
  // The add-to-cart button is replaced by a "Notify Me" button.
  comingSoon Boolean @default(false)

  orderItems OrderItem[]
  cartItems  CartItem[]
  reviews    Review[]
  stockMovements StockMovement[]
  productionBatches ProductionBatch[]
  notifyRequests NotifyRequest[]

  @@index([source])
  @@index([inStock])
  @@index([minAge, maxAge])
  @@index([comingSoon])
}

// Stores requests from users who want to be notified when a coming-soon
// product becomes available. Supports email and WhatsApp contact methods.
model NotifyRequest {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String?
  email       String?
  phone       String?   // WhatsApp number
  notified    Boolean   @default(false)
  notifiedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([productId])
  @@index([notified])
}

// Append-only audit log of every stock change. Written inside the same
// transaction as the corresponding Product update so the log is always
// in sync with the actual stock figures.
model StockMovement {
  id                  String   @id @default(cuid())
  productId           String
  variantIndex        Int?     // null when product has no variants
  delta               Int      // negative for decrement, positive for restore
  reason              String   // order_created | order_cancelled | order_uncancelled | manual_adjustment
  orderId             String?
  adminId             String?
  stockBefore         Int
  stockAfter          Int
  variantStockBefore  Int?
  variantStockAfter   Int?
  note                String?  @db.Text
  createdAt           DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([orderId])
  @@index([reason, createdAt])
}

// Suppliers we buy production inputs from (paper, supervision, manufacturing,
// etc.). Each supplier has a ledger of transactions; the live balance is
// computed at read-time as SUM(invoice) - SUM(payment) - SUM(credit-note).
// Soft-delete via isActive — hard delete is blocked by the FK on transactions.
model Supplier {
  id           String   @id @default(cuid())
  name         String   @unique
  type         String   // 'paper' | 'supervision' | 'manufacturing' | 'other'
  contactPhone String?
  contactEmail String?
  notes        String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  transactions SupplierTransaction[]
  batches      ProductionBatch[]
  @@index([type])
  @@index([isActive])
}

// Two-way ledger row.
// 'invoice'     = we owe them more (created automatically by a batch, or
//                 manually for non-batch costs).
// 'payment'     = we paid them (reduces the balance).
// 'credit-note' = they owe us back (refund / quality return).
model SupplierTransaction {
  id                String   @id @default(cuid())
  supplierId        String
  supplier          Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  kind              String
  amount            Float
  description       String?
  productionBatchId String?  // set when the row was auto-created from a batch
  createdByUserId   String?
  createdAt         DateTime @default(now())
  @@index([supplierId, createdAt])
  @@index([productionBatchId])
}

// Customer accounts-receivable ledger — mirrors SupplierTransaction but
// on the OTHER side: a positive balance means the customer (typically a
// wholesale dealer) owes us money. Used by the valuation page (positive
// receivables add to baseValue) and by the Zakat calculator (collectible
// debts are part of the Zakat pool).
model CustomerTransaction {
  id              String   @id @default(cuid())
  customerId      String
  customer        User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kind            String   // 'invoice' | 'payment' | 'credit-note'
  amount          Float
  description     String?  @db.Text
  orderId         String?  // optional link to the originating Order (for invoice kind)
  createdByUserId String?
  createdAt       DateTime @default(now())
  @@index([customerId, createdAt])
  @@index([orderId])
}

// Annual Zakat-on-trade-goods snapshot. One row per Hijri year, immutable
// after save (only paymentStatus / paymentDate / notes can be patched).
// All four valuation methods are stored alongside the chosen one so a
// future audit can see why the admin picked their method.
model ZakatSnapshot {
  id                       String   @id @default(cuid())
  hijriYear                String   @unique // e.g. "1446"
  hijriDateLabel           String   // "1 ذو الحجة 1446"
  gregorianDate            DateTime
  inventoryValuationMethod String   // 'retail' | 'wholesale' | 'avg-actual' | 'manual'
  inventoryValueRetail     Float
  inventoryValueWholesale  Float
  inventoryValueAvgActual  Float
  inventoryValueManual     Float?
  inventoryValueUsed       Float
  cashOnHand               Float    @default(0)
  receivables              Float    @default(0)
  liabilities              Float    @default(0)
  zakatPool                Float
  zakatAmount              Float
  // Gold-based nisab snapshot. Captured at save time so a future audit
  // can see what gold price was used and whether Zakat was due.
  goldPricePerGram24K      Float?   // EGP per gram of 24K gold at snapshot time
  goldPriceSource          String?  // 'manual' | 'goldprice.org' | etc.
  nisabGrams               Float?   @default(85)
  nisabValue               Float?   // = nisabGrams × goldPricePerGram24K
  zakatDue                 Boolean? @default(true) // false when pool < nisab
  excludedBatchIds         Json?    // string[] — batch IDs excluded from this calculation
  paymentStatus            String   @default("unpaid") // 'unpaid' | 'paid'
  paymentDate              DateTime?
  notes                    String?  @db.Text
  createdByUserId          String?
  createdAt                DateTime @default(now())
  items                    ZakatSnapshotItem[]
  @@index([gregorianDate])
}

// Per-product breakdown captured at snapshot time. Names are
// denormalized so a future product rename doesn't rewrite history.
model ZakatSnapshotItem {
  id              String        @id @default(cuid())
  snapshotId      String
  snapshot        ZakatSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  productId       String
  productName     String
  quantity        Int
  unitValue       Float
  totalValue      Float
  valuationMethod String
  @@index([snapshotId])
}

// Team / payroll directory.
model Employee {
  id              String   @id @default(cuid())
  name            String
  role            String
  customRole      String?
  employmentType  String
  monthlySalary   Float    @default(0)
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean  @default(true)
  notes           String?  @db.Text
  contactPhone    String?
  contactEmail    String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([isActive])
  @@index([role])
}

model RoyaltyAgreement {
  id              String    @id @default(cuid())
  payeeName       String
  contactPhone    String?
  contactEmail    String?
  percentage      Float
  productIds      Json
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean   @default(true)
  lastPaidAt      DateTime?
  notes           String?   @db.Text
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([isActive])
}

model Partner {
  id                  String    @id @default(cuid())
  name                String
  type                String
  stakePercentage     Float
  capitalContribution Float     @default(0)
  joinDate            DateTime
  exitDate            DateTime?
  isActive            Boolean   @default(true)
  contactPhone        String?
  contactEmail        String?
  notes               String?   @db.Text
  createdByUserId     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  @@index([isActive])
}

model ProductionFile {
  id           String   @id @default(cuid())
  groupId      String   // logical file group (same product/type across versions)
  productId    String?
  title        String   // display name
  fileType     String   // e.g. "design", "proof", "print-ready"
  driveFileId  String   // Google Drive file ID
  fileName     String   // original filename with extension
  mimeType     String
  sizeBytes    Int
  version      Int      @default(1)
  isLatest     Boolean  @default(true)
  status       String   @default("draft") // draft | approved | sent-to-printer | done
  notes        String?  @db.Text
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@index([groupId])
  @@index([productId])
  @@index([isLatest])
}

model ProductionBatch {
  id              String    @id @default(cuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  variantIndex    Int?
  quantity        Int
  unitCost        Float
  totalCost       Float
  batchDate       DateTime  @default(now())
  notes           String?   @db.Text
  isOpeningBalance Boolean  @default(false)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  @@index([productId, batchDate])
  @@index([supplierId])
  @@index([isOpeningBalance])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  status          String   @default("pending")
  total           Float
  shippingCost    Float    @default(0)
  discount        Float    @default(0)
  couponCode      String?
  paymentMethod   String
  paypalOrderId   String?  @unique
  shippingAddress Json
  notes           String?  @db.Text
  currency        String   @default("EGP")
  externalOrderId String?  @unique
  source          String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items          OrderItem[]
  shipment       Shipment?
  returnRequests ReturnRequest[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([userId])
  @@index([paymentMethod])
  @@index([source])
}

model Shipment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider        String   @default("bosta")
  bostaDeliveryId String?  @unique
  trackingNumber  String?  @unique
  status          String   @default("created")
  state           String?
  cod             Float    @default(0)
  notes           String?  @db.Text
  history         Json?
  rawPayload      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([trackingNumber])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  productName   String
  productImage  String?
  quantity      Int
  unitPrice     Float
  selectedModel Int?

  @@index([orderId])
  @@index([productId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id            String  @id @default(cuid())
  cartId        String
  cart          Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  quantity      Int
  selectedModel Int?

  @@index([cartId])
}

model ShippingRate {
  id            String   @id @default(cuid())
  governorateId String   @unique
  rate          Float
  updatedAt     DateTime @updatedAt
}

model Coupon {
  code              String   @id
  discount          Float
  isActive          Boolean  @default(true)
  showBanner        Boolean  @default(false)
  bannerText        String?
  bannerColor       String?
  createdByUserId   String?
  lastEditedByUserId String?
  createdAt         DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  author    String
  rating    Int
  comment   String   @db.Text
  commentEn String?  @db.Text
  verified  Boolean  @default(false)
  approved  Boolean  @default(true)
  date      DateTime @default(now())

  @@index([productId])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Book {
  id            String   @id @default(cuid())
  title         String
  titleEn       String?
  description   String   @db.Text
  descriptionEn String?  @db.Text
  cover         String   @default("")
  filePath      String   @default("")
  totalPages    Int      @default(0)
  freePages     Int      @default(10)
  price         Float    @default(0)
  priceUSD      Float?
  author        String?
  authorEn      String?
  category      String?
  language      String?  @default("ar")
  section       String?  @default("books")
  minAge        Int?
  maxAge        Int?
  needsParentalGuide Boolean @default(false)
  isPublished   Boolean  @default(false)
  allowQuoteShare   Boolean @default(true)
  allowFriendShare  Boolean @default(true)
  friendShareHours  Int     @default(48)
  enableReferral    Boolean @default(true)
  referralDiscount  Int     @default(20)
  enableWatermark   Boolean @default(true)
  enableForensic    Boolean @default(true)
  paperProductSlug  String?
  seriesId          String?
  series            BookSeries? @relation(fields: [seriesId], references: [id])
  seriesOrder       Int?
  bgmUrl            String?
  promoVideoUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accesses   BookAccess[]
  shareLinks BookShareLink[]
  bookOrders BookOrder[]
  accessLogs BookAccessLog[]
}


model BookSeries {
  id            String   @id @default(cuid())
  name          String
  nameEn        String?
  slug          String   @unique
  description   String?  @db.Text
  descriptionEn String?  @db.Text
  cover         String?
  seriesPrice   Float?
  seriesPriceUSD Float?
  language      String?  @default("ar")
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  books         Book[]
  @@index([slug])
}

model BookAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id])
  lastPage  Int      @default(1)
  grantedAt DateTime @default(now())

  @@unique([userId, bookId])
  @@index([bookId])
}

model BookShareLink {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id])
  createdBy String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([token])
}

model OAuthAccount {
  id           String   @id @default(cuid())
  provider     String
  providerAccountId String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model BookOrder {
  id            String   @id
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  bookId        String
  book          Book     @relation(fields: [bookId], references: [id])
  status        String   @default("pending")
  price         Float
  currency      String   @default("EGP")
  paymentMethod String
  paypalOrderId String?  @unique
  referrerId    String?
  referrerToken String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([userId])
  @@index([bookId])
}

model BookAccessLog {
  id          String   @id @default(cuid())
  bookId      String
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  userId      String?
  ipAddress   String?
  userAgent   String?  @db.Text
  country     String?
  city        String?
  region      String?
  latitude    Float?
  longitude   Float?
  accessedAt  DateTime @default(now())
  @@index([bookId])
  @@index([userId])
  @@index([ipAddress])
}

model BookDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint String
  userAgent   String?  @db.Text
  ipAddress   String?
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())
  @@unique([userId, fingerprint])
  @@index([userId])
}

model BookSession {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  ipAddress String?
  startedAt DateTime @default(now())
  lastPing  DateTime @default(now())
  @@index([userId, bookId])
  @@index([lastPing])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorRole   String?
  actorName   String?
  actorEmail  String?
  action      String
  entity      String?
  entityId    String?
  before      Json?
  after       Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
}

model FacebookEvent {
  id              String   @id @default(cuid())
  psid            String
  kind            String   @default("message")
  direction       String
  text            String   @db.Text
  commentId       String?
  postId          String?
  sender          Json?
  recipient       Json?
  rawPayload      Json?
  aiModel         String?
  aiTokens        Int?
  sendStatus      String?
  sendError       String?  @db.Text
  leadStatus      String?
  userGender      String?
  customerName    String?
  customerPhone   String?
  customerAddress String?  @db.Text
  customerGov     String?
  kidAges         Json?
  intentSignal    String?
  createdAt       DateTime @default(now())
  @@index([psid, createdAt])
  @@index([direction, createdAt])
  @@index([kind, createdAt])
  @@index([leadStatus, createdAt])
  @@index([customerPhone])
  @@index([intentSignal, createdAt])
  @@index([createdAt])
}

model CatalogLead {
  id               String   @id @default(cuid())
  name             String
  phone            String
  city             String
  notes            String?  @db.Text
  productName      String   @db.Text
  productId        String?
  selectedProducts Json?
  status           String   @default("new")
  orderId          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─── Wishlist Sharing ────────────────────────────────────────────────────────
model WishlistShareLink {
  id         String   @id @default(cuid())
  token      String   @unique @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productIds Json
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([token])
  @@index([userId])
}

// ─── Loyalty Points ──────────────────────────────────────────────────────────
model LoyaltyTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points    Int
  reason    String
  orderId   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Referral Rewards ────────────────────────────────────────────────────────
model ReferralReward {
  id          String    @id @default(cuid())
  referrerId  String
  referrer    User      @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  bookOrderId String    @unique
  discountPct Int
  couponCode  String?   @unique
  isUsed      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([referrerId])
}

// ─── Returns & Exchanges ─────────────────────────────────────────────────────
model ReturnRequest {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  reason       String
  reasonNote   String?  @db.Text
  status       String   @default("pending")
  itemsJson    Json
  refundAmount Decimal? @db.Decimal(10, 2)
  adminNote    String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model Child {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  birthdate DateTime
  gender    String?
  createdAt DateTime @default(now())

  @@index([userId])
}
