# ── Database ──────────────────────────────────────────────────
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME"

# ── Auth (JWT signing) ────────────────────────────────────────
JWT_SECRET="random-string-min-32-chars"

# ── App URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="https://moslimleader.com"
NEXT_PUBLIC_SITE_URL="https://moslimleader.com"

# ── Admin (super-admin email) ─────────────────────────────────
NEXT_PUBLIC_ADMIN_EMAIL="admin@moslimleader.com"
ADMIN_EMAIL="admin@moslimleader.com"

# ── PayPal (live or sandbox) ──────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID="YOUR_PAYPAL_CLIENT_ID"
PAYPAL_CLIENT_ID="YOUR_PAYPAL_CLIENT_ID"
PAYPAL_CLIENT_SECRET="YOUR_PAYPAL_CLIENT_SECRET"
PAYPAL_API_BASE="https://api-m.paypal.com"
# sandbox: https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_ID="YOUR_PAYPAL_WEBHOOK_ID"
# Optional: forces 'live' or 'sandbox' regardless of API_BASE
PAYPAL_MODE="live"

# ── Email (Titan SMTP — both transactional + marketing) ───────
SMTP_HOST="smtp.titan.email"
SMTP_PORT="465"
SMTP_USER="your@email.com"
SMTP_PASS="your-email-password"
# Optional: friendly From name on outgoing emails
SMTP_FROM_NAME="Moslim Leader"

# ── Cloudflare Turnstile (book reader anti-bot) ───────────────
TURNSTILE_SECRET_KEY="your-turnstile-secret"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAACzKEGf-IQ39WfSB"

# ── Google OAuth (optional sign-in flow) ──────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Bosta shipping (Egypt last-mile carrier) ──────────────────
BOSTA_API_TOKEN="your-token-here"
BOSTA_API_URL="https://app.bosta.co/api/v2"
BOSTA_WEBHOOK_SECRET="your-webhook-secret"
BOSTA_TRACKING_URL="https://bosta.co/tracking-shipments/{tn}"

# ── Marketing (campaign tracking + unsubscribe link signing) ──
MARKETING_SIGNING_SECRET="random-string-min-32-chars"

# ── Valuation (admin valuation page password gate) ────────────
VALUATION_PASSWORD="your-password-here"

# ── Environment ───────────────────────────────────────────────
NODE_ENV="production"
