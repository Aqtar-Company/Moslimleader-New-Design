generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash      String
  resetToken        String?  @unique
  resetTokenExpiry  DateTime?
  emailVerified           Boolean   @default(false)
  verificationToken       String?   @unique
  verificationTokenExpiry DateTime?
  phone          String?
  role           String   @default("customer")
  // For role='staff' users: array of permission keys (e.g. ['orders.read',
  // 'inventory.write']). Null/empty = no admin access. Super-admins
  // (role='admin') bypass this and have implicit access to everything.
  permissions    Json?
  // Bumped on staff revoke / explicit force-logout. JWT carries the
  // version it was signed with; verifyToken rejects when the User row's
  // current version is higher → forces re-login.
  tokenVersion   Int      @default(0)
  lastLoginAt    DateTime?
  savedAddresses Json?
  wishlistIds    Json?
  marketingOptIn Boolean  @default(false)
  marketingToken String?  @unique
  // Marks the customer as a wholesale dealer (تاجر جملة). Filterable on the
  // customer list and surfaced as a separate count on the valuation page.
  isWholesale    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders  Order[]
  cart    Cart?
  reviews Review[]
  bookAccesses BookAccess[]
  oauthAccounts OAuthAccount[]
  bookOrders    BookOrder[]
  devices       BookDevice[]
  customerTransactions CustomerTransaction[]
  campaignRecipients CampaignRecipient[]

  @@index([role])
  @@index([isWholesale])
}

model Campaign {
  id              String   @id @default(cuid())
  name            String
  channel         String   @default("email") // email | whatsapp (placeholder)
  segmentKey      String   @default("all")   // matches segments in /api/admin/customers
  segmentFilters  Json?    // { boughtProduct?, notBoughtProduct?, governorate? }
  subject         String
  bodyHtml        String   @db.LongText
  couponCode      String?  @unique // optional coupon to attach; unique so an order's coupon maps to at most one campaign for conversion attribution
  status          String   @default("draft") // draft | sending | sent | failed
  recipientCount  Int      @default(0)
  sentCount       Int      @default(0)
  openedCount     Int      @default(0)
  clickedCount    Int      @default(0)
  conversionCount Int      @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  // Attribution: which admin/staff created the campaign.
  createdByUserId String?
  // ---- Daily-drip + plain-text editor ----
  // bodyText is the new authoritative source for the message; bodyHtml
  // is derived from it at send time via renderPlainTextEmail() so the
  // assistant doesn't have to write HTML. Legacy campaigns whose
  // bodyText is null still send via the legacy bodyHtml path.
  bodyText        String?  @db.LongText
  ctaLabel        String?
  ctaUrl          String?
  // dailyLimit recipients per "send-daily-batch" click — defaults to 5
  // so the inbox doesn't look algorithmic. Drops to 0 to disable drip.
  dailyLimit      Int      @default(5)
  lastBatchAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recipients CampaignRecipient[]
  @@index([status])
}

model CampaignRecipient {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String
  status      String   @default("queued") // queued | sent | failed | bounced
  errorMessage String? @db.Text
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  orderId     String?  // attribution if a conversion happened
  createdAt   DateTime @default(now())

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
}

model Product {
  id                 String   @id @default(cuid())
  slug               String   @unique
  name               String
  nameEn             String?
  shortDescription   String   @db.Text
  shortDescriptionEn String?  @db.Text
  description        String   @db.LongText
  descriptionEn      String?  @db.LongText
  price              Float
  priceUsd           Float    @default(0)
  // Optional wholesale price for the Zakat valuation engine. When null,
  // the calculator falls back to retail × 0.85 as the wholesale proxy.
  wholesalePrice     Float?
  category           String
  subcategory        String?
  variants           Json?
  tags               Json
  images             Json
  inStock            Boolean  @default(true)
  stock              Int      @default(500)
  variantStocks      Json?    // { "0": 250, "1": 250 } — per-variant stock by index. Total `stock` = sum.
  featured           Boolean  @default(false)
  videos             Json?
  videoUrl           String?
  weight             Float    @default(0)
  regionalPricing    Json?
  source             String   @default("static")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
  reviews    Review[]
  stockMovements StockMovement[]
  productionBatches ProductionBatch[]

  @@index([source])
  @@index([inStock])
}

// Append-only audit log of every stock change. Written inside the same
// transaction as the corresponding Product update so the log is always
// in sync with the actual stock figures.
model StockMovement {
  id                  String   @id @default(cuid())
  productId           String
  variantIndex        Int?     // null when product has no variants
  delta               Int      // negative for decrement, positive for restore
  reason              String   // order_created | order_cancelled | order_uncancelled | manual_adjustment
  orderId             String?
  adminId             String?
  stockBefore         Int
  stockAfter          Int
  variantStockBefore  Int?
  variantStockAfter   Int?
  note                String?  @db.Text
  createdAt           DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([orderId])
  @@index([reason, createdAt])
}

// Suppliers we buy production inputs from (paper, supervision, manufacturing,
// etc.). Each supplier has a ledger of transactions; the live balance is
// computed at read-time as SUM(invoice) - SUM(payment) - SUM(credit-note).
// Soft-delete via isActive — hard delete is blocked by the FK on transactions.
model Supplier {
  id           String   @id @default(cuid())
  name         String   @unique
  type         String   // 'paper' | 'supervision' | 'manufacturing' | 'other'
  contactPhone String?
  contactEmail String?
  notes        String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  transactions SupplierTransaction[]
  batches      ProductionBatch[]
  @@index([type])
  @@index([isActive])
}

// Two-way ledger row.
// 'invoice'     = we owe them more (created automatically by a batch, or
//                 manually for non-batch costs).
// 'payment'     = we paid them (reduces the balance).
// 'credit-note' = they owe us back (refund / quality return).
model SupplierTransaction {
  id                String   @id @default(cuid())
  supplierId        String
  supplier          Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  kind              String
  amount            Float
  description       String?
  productionBatchId String?  // set when the row was auto-created from a batch
  createdByUserId   String?
  createdAt         DateTime @default(now())
  @@index([supplierId, createdAt])
  @@index([productionBatchId])
}

// Customer accounts-receivable ledger — mirrors SupplierTransaction but
// on the OTHER side: a positive balance means the customer (typically a
// wholesale dealer) owes us money. Used by the valuation page (positive
// receivables add to baseValue) and by the Zakat calculator (collectible
// debts are part of the Zakat pool).
model CustomerTransaction {
  id              String   @id @default(cuid())
  customerId      String
  customer        User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kind            String   // 'invoice' | 'payment' | 'credit-note'
  amount          Float
  description     String?  @db.Text
  orderId         String?  // optional link to the originating Order (for invoice kind)
  createdByUserId String?
  createdAt       DateTime @default(now())
  @@index([customerId, createdAt])
  @@index([orderId])
}

// Annual Zakat-on-trade-goods snapshot. One row per Hijri year, immutable
// after save (only paymentStatus / paymentDate / notes can be patched).
// All four valuation methods are stored alongside the chosen one so a
// future audit can see why the admin picked their method.
model ZakatSnapshot {
  id                       String   @id @default(cuid())
  hijriYear                String   @unique // e.g. "1446"
  hijriDateLabel           String   // "1 ذو الحجة 1446"
  gregorianDate            DateTime
  inventoryValuationMethod String   // 'retail' | 'wholesale' | 'avg-actual' | 'manual'
  inventoryValueRetail     Float
  inventoryValueWholesale  Float
  inventoryValueAvgActual  Float
  inventoryValueManual     Float?
  inventoryValueUsed       Float
  cashOnHand               Float    @default(0)
  receivables              Float    @default(0)
  liabilities              Float    @default(0)
  zakatPool                Float
  zakatAmount              Float
  // Gold-based nisab snapshot. Captured at save time so a future audit
  // can see what gold price was used and whether Zakat was due.
  goldPricePerGram24K      Float?   // EGP per gram of 24K gold at snapshot time
  goldPriceSource          String?  // 'manual' | 'goldprice.org' | etc.
  nisabGrams               Float?   @default(85)
  nisabValue               Float?   // = nisabGrams × goldPricePerGram24K
  zakatDue                 Boolean? @default(true) // false when pool < nisab
  paymentStatus            String   @default("unpaid") // 'unpaid' | 'paid'
  paymentDate              DateTime?
  notes                    String?  @db.Text
  createdByUserId          String?
  createdAt                DateTime @default(now())
  items                    ZakatSnapshotItem[]
  @@index([gregorianDate])
}

// Per-product breakdown captured at snapshot time. Names are
// denormalized so a future product rename doesn't rewrite history.
model ZakatSnapshotItem {
  id              String        @id @default(cuid())
  snapshotId      String
  snapshot        ZakatSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  productId       String
  productName     String
  quantity        Int
  unitValue       Float
  totalValue      Float
  valuationMethod String
  @@index([snapshotId])
}

// Team / payroll directory. Captures the people working with the
// company along with their compensation so the valuation report can
// finally compute a real OpEx instead of disclosing 'untracked'. Roles
// are free-text-ish (an enum-like predefined set + 'other' fallback)
// to keep the page simple while still reporting cleanly.
model Employee {
  id              String   @id @default(cuid())
  name            String
  role            String   // see TEAM_ROLES in src/lib/team-roles.ts
  customRole      String?  // populated when role = 'other'
  employmentType  String   // 'full-time' | 'part-time' | 'consultant' | 'contractor'
  monthlySalary   Float    @default(0) // EGP — net cost to company per month
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean  @default(true)
  notes           String?  @db.Text
  contactPhone    String?
  contactEmail    String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([isActive])
  @@index([role])
}

// Royalty / intellectual-property agreement. A rights-holder (typically
// the author) earns a percentage of the gross profit of specific
// products for a defined period. Distinct from Employee — a person who
// is both a manager and an author would have one row in each table.
//
// productIds is a JSON array of Product.id strings. Kept simple
// (no junction table) because royalties usually span a small fixed set
// of products. The percentage is applied to TTM gross profit (revenue
// minus weighted-avg COGS) of those products.
//
// lastPaidAt is a manual marker the owner toggles after issuing
// payment. v1 does not track per-payment history — phase 2 could add
// a RoyaltyPayment ledger if multi-payment audit becomes useful.
model RoyaltyAgreement {
  id              String    @id @default(cuid())
  payeeName       String
  contactPhone    String?
  contactEmail    String?
  percentage      Float     // 0–100, applied to gross profit (not revenue)
  productIds      Json      // string[] of Product.id
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean   @default(true)
  lastPaidAt      DateTime?
  notes           String?   @db.Text
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([isActive])
}

// Partners and investors — equity stakeholders, neither salaried nor
// royalty-based. Their stake informs the cap-table view in the
// valuation report (each partner's share of reconciledMid).
model Partner {
  id                  String    @id @default(cuid())
  name                String
  type                String    // 'founder' | 'investor' | 'silent-partner' | 'other'
  stakePercentage     Float     // 0–100
  capitalContribution Float     @default(0) // EGP put in (informational)
  joinDate            DateTime
  exitDate            DateTime?
  isActive            Boolean   @default(true)
  contactPhone        String?
  contactEmail        String?
  notes               String?   @db.Text
  createdByUserId     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  @@index([isActive])
}

// One manufacturing run of a product. Each batch carries its own unit cost
// (which drifts over time) so the valuation page can compute a true
// weighted-average COGS instead of the old 35% heuristic.
//
// Creating a batch atomically: increments Product.stock (or variantStocks),
// writes a StockMovement (reason='batch_created'), and — if supplierId is
// set — writes a SupplierTransaction (kind='invoice') so the supplier
// balance reflects the new debt automatically.
model ProductionBatch {
  id              String    @id @default(cuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  variantIndex    Int?      // null if the batch contributes to top-level stock
  quantity        Int
  unitCost        Float
  totalCost       Float     // denormalised = quantity × unitCost
  batchDate       DateTime  @default(now())
  notes           String?   @db.Text
  // Marks rows seeded by the legacy-stock wizard. Seed batches record the
  // historical unit cost WITHOUT incrementing Product.stock (the units
  // already exist in inventory) and without posting a SupplierTransaction
  // (the legacy stock was paid for long before the system started). The
  // valuation page treats them identically to regular batches when
  // computing weighted-average COGS.
  isOpeningBalance Boolean  @default(false)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  @@index([productId, batchDate])
  @@index([supplierId])
  @@index([isOpeningBalance])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  status          String   @default("pending")
  total           Float
  shippingCost    Float    @default(0)
  discount        Float    @default(0)
  couponCode      String?
  paymentMethod   String
  paypalOrderId   String?  @unique
  shippingAddress Json
  notes           String?  @db.Text
  currency        String   @default("EGP")
  // External reference for idempotent imports (e.g. ML-WA-123 from the
  // historical WhatsApp orders import). Null for organic orders.
  externalOrderId String?  @unique
  source          String?  // whatsapp_cleaned_ready | manual | etc. — null for organic
  // Attribution: which admin/staff created this order (manual orders).
  // Null for customer self-checkout.
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items    OrderItem[]
  shipment Shipment?

  // Indexes for the admin panel — every list/aggregate filters on
  // some combination of createdAt, status, userId, paymentMethod,
  // source. Without these the valuation route alone full-scans the
  // table 15+ times per request.
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([userId])
  @@index([paymentMethod])
  @@index([source])
}

model Shipment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider        String   @default("bosta")
  bostaDeliveryId String?  @unique
  trackingNumber  String?  @unique
  status          String   @default("created")
  state           String?
  cod             Float    @default(0)
  notes           String?  @db.Text
  history         Json?
  rawPayload      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([trackingNumber])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  productName   String
  productImage  String?
  quantity      Int
  unitPrice     Float
  selectedModel Int?

  @@index([orderId])
  @@index([productId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id            String  @id @default(cuid())
  cartId        String
  cart          Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  quantity      Int
  selectedModel Int?

  @@index([cartId])
}

model ShippingRate {
  id            String   @id @default(cuid())
  governorateId String   @unique
  rate          Float
  updatedAt     DateTime @updatedAt
}

model Coupon {
  code              String   @id
  discount          Float
  isActive          Boolean  @default(true)
  showBanner        Boolean  @default(false)
  bannerText        String?
  bannerColor       String?
  // Attribution: which admin/staff created/edited this coupon.
  createdByUserId   String?
  lastEditedByUserId String?
  createdAt         DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  author    String
  rating    Int
  comment   String   @db.Text
  commentEn String?  @db.Text
  verified  Boolean  @default(false)
  approved  Boolean  @default(true)
  date      DateTime @default(now())

  @@index([productId])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Book {
  id            String   @id @default(cuid())
  title         String
  titleEn       String?
  description   String   @db.Text
  descriptionEn String?  @db.Text
  cover         String   @default("")
  filePath      String   @default("")
  totalPages    Int      @default(0)
  freePages     Int      @default(10)
  price         Float    @default(0)
  priceUSD      Float?   // Manual USD price; if null, auto-calculated from price * 0.10
  author        String?
  authorEn      String?
  category      String?
  language      String?  @default("ar") // 'ar' | 'en' | 'ur' | 'id' | 'bn' | 'hi' | 'de' | 'fr' | 'both'
  section       String?  @default("books") // 'books' | 'stories'
  minAge        Int?     // null = no age restriction
  maxAge        Int?     // null = open-ended (minAge+), value = upper bound
  needsParentalGuide Boolean @default(false)
  isPublished   Boolean  @default(false)
  allowQuoteShare   Boolean @default(true)
  allowFriendShare  Boolean @default(true)
  friendShareHours  Int     @default(48)
  enableReferral    Boolean @default(true)
  referralDiscount  Int     @default(20)
  enableWatermark   Boolean @default(true)
  enableForensic    Boolean @default(true)
  paperProductSlug  String?  // slug of the paper version product in /shop
  seriesId          String?  // FK to BookSeries
  series            BookSeries? @relation(fields: [seriesId], references: [id])
  seriesOrder       Int?     // order within the series (1, 2, 3...)
  bgmUrl            String?  // background music URL (MP3 file path or external)
  promoVideoUrl     String?  // YouTube promo video URL
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accesses   BookAccess[]
  shareLinks BookShareLink[]
  bookOrders BookOrder[]
  accessLogs BookAccessLog[]
}


model BookSeries {
  id            String   @id @default(cuid())
  name          String   // Arabic name
  nameEn        String?  // English name
  slug          String   @unique
  description   String?  @db.Text
  descriptionEn String?  @db.Text
  cover         String?  // cover image URL
  seriesPrice   Float?   // discounted price for buying the full series
  seriesPriceUSD Float?  // USD price for full series
  language      String?  @default("ar") // 'ar' | 'en' | 'ur' | 'id' | 'bn' | 'hi' | 'de' | 'fr' | 'both'
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  books         Book[]
  @@index([slug])
}

model BookAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id])
  lastPage  Int      @default(1)
  grantedAt DateTime @default(now())

  @@unique([userId, bookId])
  @@index([bookId])
}

model BookShareLink {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id])
  createdBy String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([token])
}

model OAuthAccount {
  id           String   @id @default(cuid())
  provider     String
  providerAccountId String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model BookOrder {
  id            String   @id
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  bookId        String
  book          Book     @relation(fields: [bookId], references: [id])
  status        String   @default("pending")
  price         Float
  currency      String   @default("EGP")
  paymentMethod String
  paypalOrderId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([userId])
  @@index([bookId])
}

model BookAccessLog {
  id          String   @id @default(cuid())
  bookId      String
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  userId      String?
  ipAddress   String?
  userAgent   String?  @db.Text
  country     String?
  city        String?
  region      String?
  latitude    Float?
  longitude   Float?
  accessedAt  DateTime @default(now())
  @@index([bookId])
  @@index([userId])
  @@index([ipAddress])
}

model BookDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint String
  userAgent   String?  @db.Text
  ipAddress   String?
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())
  @@unique([userId, fingerprint])
  @@index([userId])
}

model BookSession {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  ipAddress String?
  startedAt DateTime @default(now())
  lastPing  DateTime @default(now())
  @@index([userId, bookId])
  @@index([lastPing])
}

// Append-only audit log of every admin/staff write action. Used to surface
// "who did what and when" to the super-admin and to attribute write
// operations across the app. Failure to log is non-fatal — logActionSafe()
// in src/lib/audit-log.ts swallows errors so a logging blip can never
// break the underlying business operation.
model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  // null for system / unauthenticated events
  actorRole   String?  // 'admin' | 'staff' | null
  actorName   String?  // denormalized for display when User is later deleted
  actorEmail  String?
  action      String   // e.g. 'intl-shipping.update', 'order.create', 'staff.add'
  entity      String?  // e.g. 'Setting', 'Order', 'Coupon'
  entityId    String?
  before      Json?
  after       Json?
  metadata    Json?    // free-form extras (ip, route, etc.)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
}
