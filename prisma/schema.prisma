generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash      String
  resetToken        String?  @unique
  resetTokenExpiry  DateTime?
  phone          String?
  role           String   @default("customer")
  savedAddresses Json?
  wishlistIds    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders  Order[]
  cart    Cart?
  reviews Review[]
  bookAccesses BookAccess[]
  oauthAccounts OAuthAccount[]
  bookOrders    BookOrder[]
  devices       BookDevice[]
}

model Product {
  id                 String   @id @default(cuid())
  slug               String   @unique
  name               String
  nameEn             String?
  shortDescription   String   @db.Text
  shortDescriptionEn String?  @db.Text
  description        String   @db.LongText
  descriptionEn      String?  @db.LongText
  price              Float
  priceUsd           Float    @default(0)
  category           String
  subcategory        String?
  variants           Json?
  tags               Json
  images             Json
  inStock            Boolean  @default(true)
  featured           Boolean  @default(false)
  videos             Json?
  videoUrl           String?
  weight             Float    @default(0)
  regionalPricing    Json?
  source             String   @default("static")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
  reviews    Review[]
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  status          String   @default("pending")
  total           Float
  shippingCost    Float    @default(0)
  discount        Float    @default(0)
  couponCode      String?
  paymentMethod   String
  paypalOrderId   String?  @unique
  shippingAddress Json
  notes           String?  @db.Text
  currency        String   @default("EGP")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  productName   String
  productImage  String?
  quantity      Int
  unitPrice     Float
  selectedModel Int?

  @@index([orderId])
  @@index([productId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id            String  @id @default(cuid())
  cartId        String
  cart          Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  quantity      Int
  selectedModel Int?

  @@index([cartId])
}

model ShippingRate {
  id            String   @id @default(cuid())
  governorateId String   @unique
  rate          Float
  updatedAt     DateTime @updatedAt
}

model Coupon {
  code      String   @id
  discount  Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  author    String
  rating    Int
  comment   String   @db.Text
  commentEn String?  @db.Text
  verified  Boolean  @default(false)
  approved  Boolean  @default(true)
  date      DateTime @default(now())

  @@index([productId])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Book {
  id            String   @id @default(cuid())
  title         String
  titleEn       String?
  description   String   @db.Text
  descriptionEn String?  @db.Text
  cover         String   @default("")
  filePath      String   @default("")
  totalPages    Int      @default(0)
  freePages     Int      @default(10)
  price         Float    @default(0)
  priceUSD      Float?   // Manual USD price; if null, auto-calculated from price * 0.10
  author        String?
  authorEn      String?
  category      String?
  language      String?  @default("ar") // 'ar' | 'en' | 'ur' | 'id' | 'bn' | 'hi' | 'de' | 'fr' | 'both'
  section       String?  @default("books") // 'books' | 'stories'
  minAge        Int?     // null = no age restriction
  maxAge        Int?     // null = open-ended (minAge+), value = upper bound
  needsParentalGuide Boolean @default(false)
  isPublished   Boolean  @default(false)
  allowQuoteShare   Boolean @default(true)
  allowFriendShare  Boolean @default(true)
  friendShareHours  Int     @default(48)
  enableReferral    Boolean @default(true)
  referralDiscount  Int     @default(20)
  enableWatermark   Boolean @default(true)
  enableForensic    Boolean @default(true)
  paperProductSlug  String?  // slug of the paper version product in /shop
  seriesId          String?  // FK to BookSeries
  series            BookSeries? @relation(fields: [seriesId], references: [id])
  seriesOrder       Int?     // order within the series (1, 2, 3...)
  bgmUrl            String?  // background music URL (MP3 file path or external)
  promoVideoUrl     String?  // YouTube promo video URL
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accesses   BookAccess[]
  shareLinks BookShareLink[]
  bookOrders BookOrder[]
  accessLogs BookAccessLog[]
}


model BookSeries {
  id            String   @id @default(cuid())
  name          String   // Arabic name
  nameEn        String?  // English name
  slug          String   @unique
  description   String?  @db.Text
  descriptionEn String?  @db.Text
  cover         String?  // cover image URL
  seriesPrice   Float?   // discounted price for buying the full series
  seriesPriceUSD Float?  // USD price for full series
  language      String?  @default("ar") // 'ar' | 'en' | 'ur' | 'id' | 'bn' | 'hi' | 'de' | 'fr' | 'both'
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  books         Book[]
  @@index([slug])
}

model BookAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id])
  lastPage  Int      @default(1)
  grantedAt DateTime @default(now())

  @@unique([userId, bookId])
  @@index([bookId])
}

model BookShareLink {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id])
  createdBy String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  usedCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([token])
}

model OAuthAccount {
  id           String   @id @default(cuid())
  provider     String
  providerAccountId String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([provider, providerAccountId])
}

model BookOrder {
  id            String   @id
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  bookId        String
  book          Book     @relation(fields: [bookId], references: [id])
  status        String   @default("pending")
  price         Float
  currency      String   @default("EGP")
  paymentMethod String
  paypalOrderId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([userId])
  @@index([bookId])
}

model BookAccessLog {
  id          String   @id @default(cuid())
  bookId      String
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  userId      String?
  ipAddress   String?
  userAgent   String?  @db.Text
  accessedAt  DateTime @default(now())
  @@index([bookId])
  @@index([userId])
  @@index([ipAddress])
}

model BookDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint String
  userAgent   String?  @db.Text
  ipAddress   String?
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())
  @@unique([userId, fingerprint])
  @@index([userId])
}

model BookSession {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  ipAddress String?
  startedAt DateTime @default(now())
  lastPing  DateTime @default(now())
  @@index([userId, bookId])
  @@index([lastPing])
}
